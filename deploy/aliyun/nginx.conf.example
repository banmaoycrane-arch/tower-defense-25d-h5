# 阿里云 Nginx 配置示例
# 复制到 /etc/nginx/conf.d/tower-defense.conf 后修改域名和证书路径

server {
    listen 80;
    server_name game.你的域名.com;
    # 申请 SSL 后可自动跳转 HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name game.你的域名.com;

    # 阿里云免费 SSL 或 Let's Encrypt 证书路径
    ssl_certificate     /etc/nginx/ssl/game.你的域名.com.pem;
    ssl_certificate_key /etc/nginx/ssl/game.你的域名.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
